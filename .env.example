# Beispiel-Konfiguration. Kopieren nach .env und anpassen.
# .env wird NICHT versioniert (siehe .gitignore). Keine Secrets ins Repo.

# --- Pfade ---
# Speicherort des LanceDB-Index (generiert).
LANCE_DB_PATH=./data/lance
# Wurzel der lokalen Dokumente (PDF/MD/TXT) -> source_type=document.
SOURCE_DOCS_PATH=./data/documents
# Wurzel der eigenen Notizen (Markdown) -> source_type=note.
NOTES_PATH=./data/notes

# --- Embedding / Indexierung ---
# cuda nutzt die GPU (FP16, knappes VRAM-Budget), cpu erzwingt CPU-Inferenz.
EMBED_DEVICE=cuda
# Batchgröße beim Kodieren. Bei VRAM-Mangel verkleinern.
EMBED_BATCH_SIZE=32
# Chunking in Wörtern.
CHUNK_SIZE=500
CHUNK_OVERLAP=50
# Matryoshka: Embedding-Dimension kürzen (spart DB-Platz). Leer = volle Dim (1024).
# EMBED_DIM=512

# --- MCP-Server ---
# Bind-Adresse und Port des FastMCP-Servers (SSE-Transport).
MCP_HOST=0.0.0.0
MCP_PORT=8000

# --- Capture-Dienst (Erfassen von unterwegs über Tailscale) ---
# Bindet an localhost; die Tailnet-Veröffentlichung macht 'tailscale serve'.
CAPTURE_HOST=127.0.0.1
CAPTURE_PORT=8765
# Wie viele Treffer LanceDB liefert, bevor optional umsortiert wird.
SEARCH_TOP_K=20
# Wie viele Treffer der Server am Ende zurückgibt.
SEARCH_RETURN_K=5
# Reranker (optional, siehe CLAUDE.md offene Punkte). Leer = aus.
# RERANK_MODEL=Alibaba-NLP/gte-multilingual-reranker-base
# RERANK_DEVICE=cpu

# --- Web-Ingest / Link-Prüfung ---
# Timeout (Sekunden) und User-Agent für Web-Abrufe und Erreichbarkeitsprüfung.
HTTP_TIMEOUT=20
HTTP_USER_AGENT=mykb/0.1 (+https://github.com/kaijen/mykb)
LINK_CHECK_CONCURRENCY=8

# --- Linkwarden (Bookmark-Frontend) ---
# Basis-URL und API-Token der Linkwarden-Instanz (Secret -> .env, nicht ins Repo).
# LINKWARDEN_URL=https://links.example.com
# LINKWARDEN_TOKEN=CHANGE_ME

# --- KI-Anreicherung beim Ingest (lokaler LLM via Ollama, CPU) ---
# Aus (0). Mit ENRICH=1 oder 'python -m mykb index --enrich' erzeugt ein
# lokaler LLM je Quelle Zusammenfassung + Auto-Tags. Läuft auf CPU/RAM.
ENRICH=0
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
ENRICH_MAX_CHARS=6000
