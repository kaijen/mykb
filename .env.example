# Beispiel-Konfiguration. Kopieren nach .env und anpassen.
# .env wird NICHT versioniert (siehe .gitignore). Keine Secrets ins Repo.

# --- Pfade ---
# Speicherort des LanceDB-Index (generiert).
LANCE_DB_PATH=./data/lance
# Wurzel der Quelldokumente (Unterordner: standards/, research/).
SOURCE_DOCS_PATH=./data/literatur

# --- Embedding / Indexierung ---
# cuda nutzt die GPU (FP16, knappes VRAM-Budget), cpu erzwingt CPU-Inferenz.
EMBED_DEVICE=cuda
# Batchgröße beim Kodieren. Bei VRAM-Mangel verkleinern.
EMBED_BATCH_SIZE=32
# Chunking in Wörtern.
CHUNK_SIZE=500
CHUNK_OVERLAP=50
# Matryoshka: Embedding-Dimension kürzen (spart DB-Platz). Leer = volle Dim (1024).
# EMBED_DIM=512

# --- MCP-Server ---
# Bind-Adresse und Port des FastMCP-Servers (SSE-Transport).
MCP_HOST=0.0.0.0
MCP_PORT=8000
# Wie viele Treffer LanceDB liefert, bevor optional umsortiert wird.
SEARCH_TOP_K=20
# Wie viele Treffer der Server am Ende zurückgibt.
SEARCH_RETURN_K=5
# Reranker (optional, siehe CLAUDE.md offene Punkte). Leer = aus.
# RERANK_MODEL=Alibaba-NLP/gte-multilingual-reranker-base
# RERANK_DEVICE=cpu
