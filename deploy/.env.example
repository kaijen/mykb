# Compose-Konfiguration. Kopieren nach deploy/.env (wird nicht versioniert).
# Diese Werte steuern docker-compose.laptop.yml und docker-compose.yml.

# --- Laptop: Scheduler (ereignisgesteuert) / Anreicherung ---
# Ruhezeit nach der letzten Übergabe, bevor verarbeitet wird (Bursts bündeln).
PROCESS_DEBOUNCE=30
# Poll-Takt des Watchers (Sekunden).
WATCH_POLL=5
# Fallback-Intervall ohne Trigger (Sekunden) — hält u. a. Link-Rot aktuell.
PROCESS_INTERVAL=3600
# KI-Anreicherung beim Verarbeiten (1=an).
ENRICH=1
OLLAMA_MODEL=llama3.2

# --- Laptop: Linkwarden + Postgres ---
POSTGRES_PASSWORD=CHANGE_ME
NEXTAUTH_SECRET=CHANGE_ME
LINKWARDEN_NEXTAUTH_URL=http://localhost:3000
# API-Token aus Linkwarden (Settings -> Access Tokens), für capture/links sync.
LINKWARDEN_TOKEN=CHANGE_ME

# --- Laptop: Sync zum VPS (läuft im scheduler nach jedem Lauf) ---
# Absoluter Pfad zum SSH-Key auf dem Host und das rsync-Ziel auf dem VPS.
SSH_KEY=/home/USER/.ssh/id_ed25519
VPS_SSH_TARGET=user@vps:/srv/mykb/data/lance/

# --- VPS: Traefik / Authelia ---
DOMAIN=mykb.example.com
ACME_EMAIL=admin@example.com
# Muss zum Laptop passen, falls dort EMBED_DIM gekürzt wurde (sonst leer lassen).
EMBED_DIM=
